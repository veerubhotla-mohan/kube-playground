{
  "name": "k8s-tutorial-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://veerubhotla-mohan.github.io/kube-playground",
  "scripts": {
    "dev": "vite",
    "dev:server": "node terminal-server/server.js",
    "dev:all": "concurrently -n \"vite,terminal\" -c \"green,cyan\" \"npm run dev -- --host\" \"npm run dev:server\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@webcontainer/api": "^1.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "vite": "^8.0.0",
    "vite-plugin-cross-origin-isolation": "^0.1.6"
  }
}
